modules = ["nodejs-22", "postgresql-16", "python-3.11"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
PORT = "5000"
API_PORT = "3001"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "api-server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "ingestion-worker"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "rag-app"

[[workflows.workflow]]
name = "api-server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/api-server run dev"
waitForPort = 3001

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "ingestion-worker"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/scripts run worker"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "rag-app"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/rag-app run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "API_PORT=5000 NODE_ENV=production pnpm --filter @workspace/api-server run start & pnpm --filter @workspace/scripts run worker & wait"]
build = ["bash", "-c", "pnpm --filter @workspace/rag-app run build"]

[objectStorage]
defaultBucketID = "replit-objstore-a2040b63-42f1-4634-a980-06c7e837a4cb"
