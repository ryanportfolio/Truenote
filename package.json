{
  "name": "kbase",
  "private": true,
  "version": "0.0.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.26.1",
  "scripts": {
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck",
    "lint": "pnpm -r run lint",
    "clean": "pnpm -r run clean && rm -rf node_modules",
    "dev:web": "pnpm --filter @workspace/rag-app run dev",
    "dev:api": "pnpm --filter @workspace/api-server run dev",
    "worker": "pnpm --filter @workspace/scripts run worker",
    "seed": "pnpm --filter @workspace/scripts run seed",
    "check": "pnpm -r run check",
    "test": "pnpm -r run test",
    "verify:pci-evidence": "corepack pnpm --filter @workspace/scripts run verify:pci-evidence"
  }
}
