# Ports
# API server (Express): the Vite dev server proxies /api to this port.
API_PORT=5000
# Frontend (Vite dev): Replit's preview reads PORT to bind the dev server.
PORT=5173

# Database (Neon Postgres via Replit, must have `vector` and `pg_trgm`)
DATABASE_URL=postgres://user:pass@host/dbname?sslmode=require

# OpenAI: embeddings (text-embedding-3-small) and generation (gpt-4o)
OPENAI_API_KEY=

# Mistral OCR (mistral-ocr-latest) — primary parser
MISTRAL_API_KEY=

# Cohere Rerank v3 (rerank-english-v3.0)
COHERE_API_KEY=

# Auth (Phase 2)
NEXTAUTH_SECRET=
NEXTAUTH_URL=

# Replit Object Storage (set on Replit; client picks them up from env)
REPLIT_OBJECT_STORAGE_BUCKET=

# Storage driver: set to "memory" for local scripts / tests to use an
# in-memory adapter instead of the Replit SDK. Leave unset in Replit.
RAG_STORAGE_DRIVER=

# Retrieval tunables (defaults shown)
RERANK_CONFIDENCE_THRESHOLD=0.3
RETRIEVAL_TOP_K=8
RETRIEVAL_CANDIDATE_K=40
