# Ports
#
# IMPORTANT: On Replit, port 5000 is reserved for the public webview, so the
# *frontend* must bind 5000 and the api-server has to use something else.
# The values below are the Replit-verified configuration. For purely local
# dev outside Replit, flip them (API_PORT=5000, PORT=5173) to match
# Express/Vite defaults.
# See .claude/reference/pitfalls.md for the full story.
#
# Frontend (Vite dev) — webview-exposed, must be 5000 on Replit.
PORT=5000
# API server (Express) — internal; Vite's proxy reads this at startup
# and forwards /api/* here. Pick any non-5000 port.
API_PORT=3001

# Database (Neon Postgres via Replit, must have `vector` and `pg_trgm`)
DATABASE_URL=postgres://user:pass@host/dbname?sslmode=require

# OpenRouter: approved primary answer routes (default: GPT-5.4 Nano :nitro on Azure).
# Assign this key to the ZDR guardrail; requests also enforce ZDR explicitly.
OPENROUTER_API_KEY=

# OpenAI: embeddings (text-embedding-3-small) and the opt-in eval judge.
# Direct OpenAI is never an answer-generation fallback.
OPENAI_API_KEY=

# LandingAI ADE Parse v2 (dpt-3-pro-latest) — primary document parser: OCR plus
# inline figure/screenshot description in one call. ZDR is account-level (Team/
# Enterprise plan + Org-Settings toggle), not a request parameter.
VISION_AGENT_API_KEY=

# Cohere Rerank v3 (rerank-english-v3.0)
COHERE_API_KEY=

# Auth (Phase 2A) — bootstrap-on-startup creates the first super_user from
# these values if no active super_user exists in the DB. Idempotent; after
# the first login + forced password reset, the env vars are unused.
BOOTSTRAP_SUPER_USER_EMAIL=
BOOTSTRAP_SUPER_USER_PASSWORD=
# Optional, defaults to "Super User".
BOOTSTRAP_SUPER_USER_NAME=
# Single-factor local/break-glass passwords require at least 15 characters.
# Larger values are allowed; values below 15 fall back to 15.
MIN_PASSWORD_LENGTH=15

# Enterprise SSO (generic OpenID Connect Authorization Code + PKCE).
# Configure all five values together. Identity emails must already exist as
# active Truenote users; no just-in-time account creation occurs.
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=https://your-truenote-host/api/auth/oidc/callback
# Random secret, at least 32 characters, used only to sign short-lived state.
OIDC_STATE_SECRET=
# Recommended: require MFA evidence and configure the IdP to emit `amr: ["mfa"]`.
OIDC_REQUIRE_MFA=true
# Optional exact assurance-context claim and comma-separated email domains.
OIDC_REQUIRED_ACR=
OIDC_ALLOWED_DOMAINS=
# enabled | break_glass | disabled. Keep enabled through the SSO smoke test;
# switch to break_glass only after SSO and MFA evidence are verified.
LOCAL_LOGIN_MODE=enabled

# Demo mode (OPTIONAL — demo deployments only). JSON array of accounts the
# login page pre-fills. Everything here is PUBLISHED via the
# unauthenticated /api/config endpoint — that is the feature. Users are
# created at startup (idempotent, must_reset_password=false); roles are
# capped at "manager". NEVER set on a deployment holding real content.
# Example:
# DEMO_LOGIN_ACCOUNTS=[{"label":"Manager","email":"manager@demo.truenote","password":"try-truenote","role":"manager"},{"label":"CSR","email":"csr@demo.truenote","password":"try-truenote"}]
DEMO_LOGIN_ACCOUNTS=

# CORS allowlist for cross-origin credentialed requests. Comma-separated.
# Leave unset in the standard Replit topology (same-origin); only set if
# the SPA runs on a different origin than the API (e.g., separate CDN).
CORS_ALLOWED_ORIGINS=

# Replit Object Storage (set on Replit; client picks them up from env)
REPLIT_OBJECT_STORAGE_BUCKET=

# Storage driver: set to "memory" for local scripts / tests to use an
# in-memory adapter instead of the Replit SDK. Leave unset in Replit.
RAG_STORAGE_DRIVER=

# Organization-approved malware scanner. Truenote sends raw bytes only to
# this configured endpoint; no public scanner is selected. Endpoint returns
# JSON: {"verdict":"clean"|"infected","engine":"...","scanId":"..."}.
# Production requires HTTPS. Missing/unavailable scanner quarantines uploads.
MALWARE_SCANNER_URL=
MALWARE_SCANNER_TOKEN=
MALWARE_SCANNER_HMAC_KEY=

# Optional signed SIEM webhook. Audit events persist and enter the durable
# database outbox atomically before asynchronous delivery. Signing key must be
# at least 32 characters. Defaults: poll 10s, batch 25, concurrency 5, lease
# 60s, 8 attempts, unhealthy backlog after 300s.
SIEM_WEBHOOK_URL=
SIEM_WEBHOOK_SIGNING_KEY=
SIEM_DELIVERY_POLL_MS=10000
SIEM_DELIVERY_BATCH_SIZE=25
SIEM_DELIVERY_CONCURRENCY=5
SIEM_DELIVERY_LEASE_SECONDS=60
SIEM_DELIVERY_MAX_ATTEMPTS=8
SIEM_DELIVERY_SLO_SECONDS=300

# Distributed /ask limits (Postgres-backed; defaults shown).
ASK_RATE_LIMIT_WINDOW_SECONDS=60
ASK_RATE_LIMIT_PER_USER=30
ASK_RATE_LIMIT_PER_PROGRAM=300

# Permanent document purge is retention-gated. Leave false unless Security has
# approved an emergency/legal deletion process.
ALLOW_RETENTION_OVERRIDE=false

# Retrieval tunables (defaults shown)
RERANK_CONFIDENCE_THRESHOLD=0.3
RETRIEVAL_TOP_K=8
RETRIEVAL_CANDIDATE_K=40

# Provider deadlines (defaults shown). Every external call is bounded by an
# explicit per-request timeout (ms) + retry cap so a stalled provider can't
# leave a CSR waiting; ASK_DEADLINE_MS is the overall /ask budget that fails
# closed with the canned refusal. Timeouts clamp to [100, 600000] ms, retries
# to [0, 5], ASK_DEADLINE_MS to [1000, 300000]. See lib/deadlines.ts.
EMBED_QUERY_TIMEOUT_MS=5000
EMBED_QUERY_MAX_RETRIES=1
EMBED_INGEST_TIMEOUT_MS=30000
EMBED_INGEST_MAX_RETRIES=2
RERANK_TIMEOUT_MS=5000
RERANK_MAX_RETRIES=1
GENERATION_TIMEOUT_MS=20000
GENERATION_MAX_RETRIES=1
REWRITE_TIMEOUT_MS=5000
REWRITE_MAX_RETRIES=1
NAME_SESSION_TIMEOUT_MS=5000
NAME_SESSION_MAX_RETRIES=1
FAITHFULNESS_TIMEOUT_MS=60000
FAITHFULNESS_MAX_RETRIES=2
DOCUMENT_PARSE_TIMEOUT_MS=120000
DOCUMENT_PARSE_MAX_RETRIES=2
ASK_DEADLINE_MS=45000
