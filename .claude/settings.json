{
  "skillOverrides": {
    "addskill": "off",
    "applying-best-practices": "off",
    "brainstorming": "off",
    "conflict": "off",
    "dispatching-parallel-agents": "off",
    "executing-plans": "off",
    "finishing-a-development-branch": "off",
    "humanizer": "off",
    "impartial-review": "off",
    "lab": "off",
    "safe-ship": "off",
    "subagent-driven-development": "off",
    "systematic-debugging": "off",
    "test-driven-development": "off",
    "using-git-worktrees": "off",
    "using-superpowers": "off",
    "verification-before-completion": "off",
    "why": "off",
    "writing-plans": "off",
    "writing-skills": "off"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(grep *)",
      "Bash(gh pr merge*)",
      "Bash(ls)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(find *)",
      "Bash(rg *)",
      "Bash(mkdir *)",
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git remote *)",
      "Bash(git diff *)",
      "Bash(git show *)",
      "Bash(git ls-tree *)",
      "Bash(git ls-files)",
      "Bash(git ls-files *)",
      "Bash(git branch)",
      "Bash(git branch *)",
      "Bash(git fetch)",
      "Bash(git fetch *)",
      "Bash(git blame *)",
      "Bash(git rev-parse *)",
      "Bash(git check-ignore *)",
      "Bash(git worktree list)",
      "Bash(git worktree list *)",
      "Bash(git stash list)",
      "Bash(gh pr view *)",
      "Bash(gh pr list)",
      "Bash(gh pr list *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr checks *)",
      "Bash(gh pr status)",
      "Bash(gh repo view *)",
      "Bash(gh run list *)",
      "Bash(gh run view *)",
      "Bash(gh issue view *)",
      "Bash(gh issue list *)"
    ]
  }
}